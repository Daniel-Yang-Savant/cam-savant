{
  "name": "cam-savant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "publish-post": "tsx scripts/publish-from-pdf.ts",
    "prompts": "ts-node scripts/today-tasks.ts",
    "draft": "ts-node scripts/convert-drafts.ts",
    "publish": "ts-node scripts/publish.ts",
    "add-topic": "ts-node -e \"const fs=require('fs'); const t=JSON.parse(fs.readFileSync('scripts/topics.json')); t.push({slug:process.argv[3], title:process.argv[1], query:process.argv[2], done:false}); fs.writeFileSync('scripts/topics.json', JSON.stringify(t, null, 2));\"",
    "rotate-token": "ts-node scripts/rotate-token.ts",
    "new": "ts-node scripts/new-article.ts"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "next": "14.2.5",
    "next-mdx-remote": "^6.0.0",
    "node-fetch": "^2.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^20.19.37",
    "@types/node-fetch": "^2.6.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
