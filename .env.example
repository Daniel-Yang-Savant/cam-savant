# ── Claude API ────────────────────────────────────────────────────────────
# 從 https://console.anthropic.com/settings/keys 取得
ANTHROPIC_API_KEY=

# ── Unsplash API ──────────────────────────────────────────────────────────
# 從 https://unsplash.com/developers 建立 Application 後取得 Access Key
# 審核中可留空，系統會自動切換到 Pexels 備用
UNSPLASH_ACCESS_KEY=

# ── Pexels API（備用圖片來源）────────────────────────────────────────────
# 從 https://www.pexels.com/api/ 申請，馬上可用，免費
PEXELS_API_KEY=

# ── Perioperative Rehab 存取保護 ──────────────────────────────────────────
# 自訂難以猜測的英數字串，QR Code 即指向含此 token 的網址
NEXT_PUBLIC_PERIOP_ACCESS_TOKEN=your_secret_token_here
